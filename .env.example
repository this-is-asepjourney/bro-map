# Kunci Google Cloud (Places API New — Text Search + Place Details)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
DATABASE_URL=postgresql+psycopg://geofinder:password@localhost:5433/geofinder
# URL untuk Streamlit saat dijalankan di host (hindari bentrok dengan app lain di port 8000)
API_URL=http://127.0.0.1:8010/api
MAX_RESULTS_LIMIT=50
CACHE_TTL_HOURS=168
# Coba ekstrak email dari situs web bisnis (Places API tidak menyediakan email). false = nonaktif.
EMAIL_SCRAPE_FROM_WEBSITE=true
