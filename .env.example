# =============================================================================
# .env.example — salin jadi `.env` lalu isi nilai yang sebenarnya.
# JANGAN commit `.env` (sudah ada di .gitignore).
#
# Di Coolify: isi semua variabel di tab "Environment Variables" pada UI.
# =============================================================================

# --- Google Maps Platform ---
# Aktifkan "Places API (New)" di Google Cloud Console dan restrict API key
# berdasarkan HTTP referrer / IP sebelum dipakai production.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# --- Database (PostGIS) ---
# Kredensial yang dipakai service `db` di docker-compose.
POSTGRES_USER=geofinder
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=geofinder

# URL connection untuk backend.
# Local (tanpa docker compose, langsung pakai DB di host 5433):
#   DATABASE_URL=postgresql+asyncpg://geofinder:password@localhost:5433/geofinder
# Compose / Coolify (backend connect ke service `db`):
#   DATABASE_URL=postgresql+asyncpg://geofinder:password@db:5432/geofinder
DATABASE_URL=postgresql+asyncpg://geofinder:change_me_to_a_strong_password@db:5432/geofinder

# --- Frontend → Backend URL ---
# Saat di compose, frontend (Python container) connect ke backend lewat DNS service.
# Saat dev di host (tanpa compose untuk frontend), pakai http://127.0.0.1:8010/api.
API_URL=http://backend:8000/api

# --- App tuning ---
MAX_RESULTS_LIMIT=50
CACHE_TTL_HOURS=168
